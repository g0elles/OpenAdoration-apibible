# Normalize line endings: text files stored LF in the repo, checked out native.
* text=auto

# Source is always LF (avoids the CRLF churn warnings).
*.cs   text eol=lf
*.csproj text eol=lf
*.slnx text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.ps1  text eol=lf
*.yml  text eol=lf

# The checked-in contract assembly is binary.
*.dll  binary
